model Session {
    id        String @id @default(uuid())
    token     String @unique

    userId    String
    user      User @relation(fields: [userId], references: [id])

    userAgent String?
    ip        String?

    expiresAt DateTime
    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    refreshTokens RefreshToken[]

    @@index([userId])
}
